# Path-specific compile databases generated by `bun run prepare:clangd`.

---
If:
  PathMatch: tools/reference-dump/.*|box3d/samples/.*
CompileFlags:
  CompilationDatabase: .reference-dumps/reference-build

---
If:
  PathMatch: packages/box3d-wasm/cmake/.*\.c
CompileFlags:
  CompilationDatabase: packages/box3d-wasm/build-native

---
If:
  PathMatch: box3d/(include|shared|src)/.*
CompileFlags:
  CompilationDatabase: .reference-dumps/reference-build

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
