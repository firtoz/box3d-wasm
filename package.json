{
  "name": "box3d-wasm-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "oxlint .",
    "format": "oxfmt . --write --ignore-path .oxfmtignore",
    "dump:wasm": "bun scripts/wasm-dump.ts",
    "compare:dumps": "bun scripts/compare-dumps.ts",
    "compare:sample": "bash scripts/compare-sample.sh",
    "typecheck": "bun run typecheck:workspace && bun run typecheck:scripts",
    "test:reference-dump": "bash scripts/reference-dump-smoke.sh",
    "prepare:clangd": "bash scripts/prepare-clangd.sh",
    "clean": "turbo run clean",
    "typecheck:scripts": "bunx tsc -p packages/box3d-wasm/scripts/tsconfig.json --noEmit",
    "typecheck:workspace": "bunx tsc -p packages/box3d-wasm/tsconfig.json --noEmit && bunx tsc -p demo/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "turbo": "^2.10.2"
  },
  "packageManager": "bun@1.2.0",
  "catalog": {
    "typescript": "7.0.1-rc",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/three": "^0.185.0"
  }
}
